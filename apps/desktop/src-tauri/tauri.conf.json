{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Code Base Scanner",
  "version": "0.1.0",
  "identifier": "com.darkworld.codebasescanner",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Code Base Scanner",
        "width": 1480,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "appimage", "deb", "rpm"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["backend/*"],
    "shortDescription": "Local-first desktop security scanning platform",
    "longDescription": "Cross-platform desktop security scanning platform with local repository analysis, scanner orchestration, reporting, and advisory updates."
  }
}
