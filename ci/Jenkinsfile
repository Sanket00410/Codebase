pipeline {
  agent any

  stages {
    stage('Install') {
      steps {
        sh 'npm install'
        sh 'python3 -m pip install --upgrade pip setuptools wheel pyinstaller'
        sh 'python3 -m pip install ./services/scanner-core'
      }
    }

    stage('Build Backend') {
      steps {
        sh './scripts/build-backend.sh'
      }
    }

    stage('Build Desktop') {
      steps {
        sh 'npm --workspace apps/desktop run tauri build'
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'apps/desktop/src-tauri/target/release/bundle/**/*', fingerprint: true
    }
  }
}
